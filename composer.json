{
    "name": "mailermine/mailermine",
    "description": "The official MailerMine PHP & Laravel SDK for transactional email, campaigns, contacts, analytics, and webhooks.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://mailermine.com",
    "keywords": [
        "mailermine",
        "email",
        "sdk",
        "laravel",
        "api",
        "transactional-email",
        "marketing",
        "campaigns",
        "webhooks",
        "analytics"
    ],
    "authors": [
        {
            "name": "MailerMine",
            "email": "support@mailermine.com",
            "homepage": "https://mailermine.com"
        }
    ],
    "support": {
        "issues": "https://github.com/rahulyadav5192/mailermine-laravel-sdk/issues",
        "source": "https://github.com/rahulyadav5192/mailermine-laravel-sdk",
        "docs": "https://mailermine.com/docs/sdk/php",
        "email": "support@mailermine.com"
    },
    "require": {
        "php": "^8.3",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.3",
        "guzzlehttp/psr7": "^1.7 || ^2.0",
        "psr/http-message": "^1.1 || ^2.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/framework": "^12.0 || ^13.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0 || ^11.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "MailerMine\\": "src/",
            "OpenAPI\\Client\\": "generated/lib/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "MailerMine\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MailerMine\\Laravel\\MailerMineServiceProvider"
            ],
            "aliases": {
                "MailerMine": "MailerMine\\Facades\\MailerMine"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:feature": "phpunit --testsuite=Feature",
        "test:coverage": "phpunit --coverage-text",
        "lint": "pint",
        "test:lint": "pint --test",
        "analyse": "phpstan analyse --memory-limit=1G",
        "test:types": "phpstan analyse --no-progress --memory-limit=1G",
        "check": [
            "@test:lint",
            "@test:types",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "test": "Run the PHPUnit test suite.",
        "lint": "Fix code style with Laravel Pint.",
        "test:lint": "Check code style without making changes.",
        "analyse": "Run PHPStan static analysis.",
        "check": "Run style, static analysis, and tests."
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
